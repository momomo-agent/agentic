{
  "name": "agentic-render",
  "version": "0.4.3",
  "type": "module",
  "description": "Streaming Markdown renderer",
  "main": "./dist/agentic-render.cjs",
  "module": "./src/index.js",
  "browser": "./dist/agentic-render.umd.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/agentic-render.cjs",
      "browser": "./dist/agentic-render.umd.js"
    },
    "./editor": {
      "import": "./src/editor.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "vite": "catalog:"
  },
  "dependencies": {
    "@milkdown/core": "^7.6.0",
    "@milkdown/ctx": "^7.6.0",
    "@milkdown/plugin-listener": "^7.6.0",
    "@milkdown/preset-commonmark": "^7.6.0",
    "@milkdown/preset-gfm": "^7.6.0"
  }
}
