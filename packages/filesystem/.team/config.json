{
  "version": "3.1",
  "description": "AI \u5f00\u53d1\u56e2\u961f - \u591a\u7ec4\u4ef6\u652f\u6301",
  "dashboard": {
    "left": [
      {
        "title": "\u613f\u666f",
        "components": [
          {
            "component": "MarkdownView",
            "path": "VISION.md",
            "gapKey": "vision",
            "label": "Vision"
          }
        ],
        "badge": {
          "source": ".team/gaps/vision.json",
          "field": "match"
        }
      },
      {
        "title": "\u4ea7\u54c1\u9700\u6c42",
        "components": [
          {
            "component": "MarkdownView",
            "path": "PRD.md",
            "gapKey": "prd",
            "label": "PRD"
          }
        ],
        "badge": {
          "source": ".team/gaps/prd.json",
          "field": "match"
        }
      },
      {
        "title": "\u9884\u671f\u9a8c\u6536",
        "components": [
          {
            "component": "MarkdownView",
            "path": "EXPECTED_DBB.md",
            "gapKey": "dbb",
            "label": "DBB"
          }
        ],
        "badge": {
          "source": ".team/gaps/dbb.json",
          "field": "match"
        }
      },
      {
        "title": "\u6280\u672f\u67b6\u6784",
        "components": [
          {
            "component": "MarkdownView",
            "path": "ARCHITECTURE.md",
            "gapKey": "architecture",
            "label": "Architecture"
          }
        ],
        "badge": {
          "source": ".team/gaps/architecture.json",
          "field": "match"
        }
      }
    ],
    "right": [
      {
        "title": "Pipeline",
        "components": [
          {
            "component": "PipelineView",
            "path": ".team/milestones/milestones.json"
          }
        ]
      },
      {
        "title": "Kanban",
        "components": [
          {
            "component": "KanbanView",
            "path": ".team/kanban.json"
          }
        ]
      },
      {
        "title": "Milestones",
        "components": [
          {
            "component": "MilestonesView",
            "path": ".team/milestones/milestones.json"
          }
        ]
      }
    ]
  },
  "workflow": {
    "entry": "startup",
    "context": {
      "todoCount": "tasks.byStatus('todo').length",
      "designedTasks": "tasks.byStatus('todo').filter(t => t.hasDesign).length",
      "todoWithoutDesign": "tasks.byStatus('todo').filter(t => !t.hasDesign).length",
      "reviewCount": "tasks.byStatus('review').length",
      "doneCount": "tasks.byStatus('done').length",
      "inProgressCount": "tasks.byStatus('inProgress').length",
      "testingCount": "tasks.byStatus('testing').length",
      "blockedCount": "tasks.byStatus('blocked').length",
      "milestoneNeedsDBB": "milestones.active() && !files.exists(milestones.active().path + '/dbb.md') ? 1 : 0",
      "archNeedsUpdate": "files.exists('ARCHITECTURE.md') && gaps.read('architecture').match < 70 ? 1 : 0",
      "goalMet": "gaps.read('vision').match >= 90 && gaps.read('prd').match >= 90 ? 1 : 0"
    },
    "nodes": {
      "startup": "nodes/startup.json",
      "monitor": "nodes/monitor.json",
      "pm_decide": "nodes/pm-decide.json",
      "work_loop": "nodes/work-loop.json",
      "milestone_qg": "nodes/milestone-qg.json",
      "standby": "nodes/standby.json",
      "complete": "nodes/complete.json"
    }
  },
  "agents": {
    "architect": {
      "prompt": "prompts/architect.md",
      "model": "claude-sonnet-4",
      "description": "\u8bbe\u8ba1\u7cfb\u7edf\u67b6\u6784",
      "onFail": {
        "maxRetries": 3,
        "fallbackShell": "echo \"# Minimal Architecture\" > ARCHITECTURE.md"
      }
    },
    "vision_monitor": {
      "prompt": "prompts/vision_monitor.md",
      "model": "claude-sonnet-4",
      "description": "\u8bc4\u4f30\u613f\u666f\u5339\u914d\u5ea6"
    },
    "prd_monitor": {
      "prompt": "prompts/prd_monitor.md",
      "model": "claude-sonnet-4",
      "description": "\u8bc4\u4f30PRD\u5339\u914d\u5ea6"
    },
    "dbb_monitor": {
      "prompt": "prompts/dbb_monitor.md",
      "model": "claude-sonnet-4",
      "description": "\u8bc4\u4f30DBB\u5339\u914d\u5ea6"
    },
    "arch_monitor": {
      "prompt": "prompts/arch_monitor.md",
      "model": "claude-sonnet-4",
      "description": "\u8bc4\u4f30\u67b6\u6784\u5339\u914d\u5ea6"
    },
    "pm": {
      "prompt": "prompts/pm.md",
      "model": "claude-sonnet-4",
      "description": "\u7ba1\u7406\u4efb\u52a1\u548c\u91cc\u7a0b\u7891"
    },
    "qa_lead": {
      "prompt": "prompts/qa_lead.md",
      "model": "claude-sonnet-4",
      "description": "\u7f16\u5199\u9a8c\u6536\u6807\u51c6"
    },
    "tech_lead": {
      "prompt": "prompts/tech_lead.md",
      "model": "claude-sonnet-4",
      "description": "\u51fa\u6280\u672f\u65b9\u6848",
      "onFail": {
        "maxRetries": 3,
        "fallbackShell": "echo \"# Minimal Design\" > .team/docs/design.md"
      }
    },
    "developer": {
      "prompt": "prompts/developer.md",
      "model": "claude-sonnet-4",
      "scalable": true,
      "description": "\u5b9e\u73b0\u529f\u80fd",
      "gitCommit": true,
      "gitPrefix": "feat"
    },
    "tester": {
      "prompt": "prompts/tester.md",
      "model": "claude-sonnet-4",
      "scalable": true,
      "description": "\u9a8c\u8bc1\u529f\u80fd",
      "gitCommit": true,
      "gitPrefix": "test"
    }
  },
  "docs": {
    "root": ".team/docs"
  },
  "monitor": {
    "root": ".team/monitor",
    "agents": [
      "vision_monitor",
      "prd_monitor",
      "dbb_monitor",
      "arch_monitor"
    ]
  },
  "git": {
    "commitPerTask": true,
    "tagPerMilestone": true
  },
  "notify": {
    "webhooks": [],
    "macos": true
  },
  "goal": {
    "condition": "gaps.read('vision').match >= 90 && gaps.read('prd').match >= 90",
    "description": "Vision \u226590% + PRD \u226590%"
  },
  "requiredFiles": [
    "VISION.md",
    "PRD.md"
  ],
  "groups": {
    "label": "milestones"
  },
  "_workflow": "project",
  "name": "agentic-filesystem",
  "created": "2026-04-07T03:07:06.479Z",
  "devteamVersion": "2.0"
}