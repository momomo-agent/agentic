{
  "name": "agentic",
  "version": "0.3.0",
  "type": "module",
  "description": "给 AI 造身体 — unified entry point for all agentic capabilities",
  "main": "./dist/agentic.cjs",
  "module": "./dist/agentic.es.js",
  "browser": "./dist/agentic.umd.js",
  "exports": {
    ".": {
      "import": "./dist/agentic.es.js",
      "require": "./dist/agentic.cjs",
      "browser": "./dist/agentic.umd.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "vite build"
  },
  "license": "MIT",
  "dependencies": {
    "agentic-act": "file:../act",
    "agentic-claw": "file:../claw",
    "agentic-client": "file:../client",
    "agentic-conductor": "file:../conductor",
    "agentic-core": "file:../core",
    "agentic-embed": "file:../embed",
    "agentic-filesystem": "file:../filesystem",
    "agentic-memory": "file:../memory",
    "agentic-render": "file:../render",
    "agentic-sense": "file:../sense",
    "agentic-shell": "file:../shell",
    "agentic-spatial": "file:../spatial",
    "agentic-store": "file:../store",
    "agentic-voice": "file:../voice"
  },
  "devDependencies": {
    "vite": "catalog:"
  }
}
